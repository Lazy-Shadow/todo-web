<div id="task-modal" class="hidden fixed inset-0 bg-black/50 modal-overlay z-50 flex items-center justify-center p-4">
  <div class="bg-white rounded-2xl w-full max-w-lg shadow-2xl">
    <div class="px-6 py-5 border-b border-gray-100">
      <div class="flex items-center justify-between">
        <h2 id="task-modal-title" class="text-xl font-bold text-gray-800">Add Task</h2>
        <button id="close-task-modal" class="p-2 hover:bg-gray-100 rounded-lg">
          <i class="fas fa-times text-gray-600"></i>
        </button>
      </div>
    </div>

    <div class="px-6 py-5 space-y-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Title</label>
        <input type="text" id="task-title" placeholder="Enter title..." 
          class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500">
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Description</label>
        <textarea id="task-description" rows="3" placeholder="Enter description..." 
          class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500 resize-none"></textarea>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Category</label>
        <div class="relative">
          <i class="fas fa-folder absolute left-3 top-1/2 -translate-y-1/2 text-gray-400"></i>
          <input type="text" id="task-category" placeholder="Enter category..." 
            class="w-full pl-10 pr-4 py-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500">
        </div>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">Priority</label>
        <div class="flex gap-2">
          <button class="priority-btn flex-1 py-2 rounded-lg border-2 text-sm font-medium border-gray-300 text-gray-600" data-priority="0">Low</button>
          <button class="priority-btn flex-1 py-2 rounded-lg border-2 text-sm font-medium bg-orange-100 border-orange-300 text-orange-700" data-priority="1">Medium</button>
          <button class="priority-btn flex-1 py-2 rounded-lg border-2 text-sm font-medium border-gray-300 text-gray-600" data-priority="2">High</button>
        </div>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Due Date</label>
        <div class="relative">
          <div id="date-picker-trigger" class="flex items-center gap-2 px-4 py-2.5 border border-gray-300 rounded-lg cursor-pointer hover:bg-gray-50">
            <i class="fas fa-calendar-alt text-gray-400"></i>
            <span id="date-picker-display" class="text-gray-600">No date</span>
          </div>
          <div id="date-picker" class="hidden absolute left-0 bottom-full mb-2 w-80 overflow-hidden bg-white rounded-xl shadow-xl border border-gray-200 z-50 p-4">
            <div class="flex items-center justify-between mb-4">
              <button id="prev-month" class="p-2 hover:bg-gray-100 rounded-lg">
                <i class="fas fa-chevron-left text-gray-600"></i>
              </button>
              <span id="current-month" class="font-semibold text-gray-800"></span>
              <button id="next-month" class="p-2 hover:bg-gray-100 rounded-lg">
                <i class="fas fa-chevron-right text-gray-600"></i>
              </button>
            </div>
            <div class="grid grid-cols-7 gap-1 mb-2">
              <span class="text-center text-xs text-gray-400">Su</span>
              <span class="text-center text-xs text-gray-400">Mo</span>
              <span class="text-center text-xs text-gray-400">Tu</span>
              <span class="text-center text-xs text-gray-400">We</span>
              <span class="text-center text-xs text-gray-400">Th</span>
              <span class="text-center text-xs text-gray-400">Fr</span>
              <span class="text-center text-xs text-gray-400">Sa</span>
            </div>
            <div id="calendar-days" class="grid grid-cols-7 gap-1"></div>
            <div class="mt-3 pt-3 border-t border-gray-100">
              <p class="text-xs text-gray-500 mb-2">Time</p>
              <div class="flex items-center gap-2">
                <input type="time" id="task-time" class="flex-1 px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-purple-500">
                <button id="clear-time" class="px-3 py-2 border border-gray-300 rounded-lg hover:bg-gray-50 text-gray-500 text-sm">
                  Clear
                </button>
              </div>
            </div>
            <div class="mt-3 pt-3 border-t border-gray-100">
              <p class="text-xs text-gray-500 mb-2">Quick options</p>
              <div class="flex flex-wrap gap-2">
                <button class="quick-date px-3 py-1.5 text-sm bg-gray-100 hover:bg-gray-200 rounded-lg" data-days="0">Today</button>
                <button class="quick-date px-3 py-1.5 text-sm bg-gray-100 hover:bg-gray-200 rounded-lg" data-days="1">Tomorrow</button>
                <button class="quick-date px-3 py-1.5 text-sm bg-gray-100 hover:bg-gray-200 rounded-lg" data-days="7">Next Week</button>
                <button class="quick-date px-3 py-1.5 text-sm bg-gray-100 hover:bg-gray-200 rounded-lg" data-days="30">Next Month</button>
              </div>
            </div>
            <div class="mt-3 pt-3 border-t border-gray-100 flex justify-between">
              <button id="clear-date" class="text-sm text-red-500 hover:text-red-600">Clear</button>
              <button id="close-date-picker" class="text-sm text-gray-500 hover:text-gray-600">Done</button>
            </div>
          </div>
        </div>
      </div>

      <button id="save-task" class="w-full bg-purple-600 text-white py-3 rounded-xl font-medium hover:bg-purple-700 transition">
        Add Task
      </button>
    </div>
  </div>
</div>

<div id="note-modal" class="hidden fixed inset-0 bg-black/50 modal-overlay z-50 flex items-center justify-center p-4">
  <div class="bg-white rounded-2xl w-full max-w-2xl shadow-2xl">
    <div class="px-6 py-5 border-b border-gray-100">
      <div class="flex items-center justify-between">
        <h2 id="note-modal-title" class="text-xl font-bold text-gray-800">New Note</h2>
        <div class="flex items-center gap-2">
          <button id="note-pin-btn" class="hidden p-2 hover:bg-gray-100 rounded-lg" title="Pin">
            <i class="fas fa-thumbtack text-gray-600"></i>
          </button>
          <button id="note-delete-btn" class="hidden p-2 hover:bg-red-50 text-red-600 rounded-lg" title="Delete">
            <i class="fas fa-trash"></i>
          </button>
          <button id="close-note-modal" class="p-2 hover:bg-gray-100 rounded-lg">
            <i class="fas fa-times text-gray-600"></i>
          </button>
        </div>
      </div>
    </div>

    <div class="px-6 py-5 space-y-4">
      <input type="text" id="note-title" placeholder="Title" 
        class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500 text-xl font-bold">
      
      <textarea id="note-content" placeholder="Start writing..." 
        class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500 resize-none h-64"></textarea>

      <button id="save-note" class="w-full bg-purple-600 text-white py-3 rounded-xl font-medium hover:bg-purple-700 transition">
        Save Note
      </button>
    </div>
  </div>
</div>
